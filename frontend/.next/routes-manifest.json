        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/mto/(?<nxtPid>[^/]+?)/edit(?:/)?$"
    },
    {
      "page": "/spp-request/[id]",
      "regex": "^/spp\\-request/([^/]+?)(?:/)?$",
