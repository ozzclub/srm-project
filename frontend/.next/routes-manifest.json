{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/do-number/[id]",
      "regex": "^/do\\-number/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/do\\-number/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/documents/[transactionId]",
      "regex": "^/documents/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPtransactionId": "nxtPtransactionId"
