{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/movement-log/layout,_N_T_/movement-log/page,_N_T_/movement-log"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/movement-log/__PAGE__",
    "/movement-log",
    "/_index",
    "/_head"
  ]
}