# Environment
NODE_ENV=development
PORT=6000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=material_control

# Auto Migration (true/false)
# When true, server will automatically check and update database structure on startup
AUTO_MIGRATE=true

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880
MAX_FILES=10

# CORS Configuration
# Allowed origins for Cloudflare tunnel setup
# Add your frontend domain and any other domains that need access
CORS_ORIGIN=http://localhost:6001,https://jastipravita.co,http://jastipravita.co,https://backend.jastipravita.co,http://backend.jastipravita.co
